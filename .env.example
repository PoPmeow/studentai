# ===== Core brain =====
# สร้าง key ฟรีได้ที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
MODEL=gemini-2.5-flash

# Groq = ตัวสำรองตอน Gemini ติด limit (ฟรี โควต้าเยอะ): https://console.groq.com/keys
GROQ_API_KEY=
# llama-3.3-70b-versatile (ฉลาด) หรือ llama-3.1-8b-instant (โควต้าเยอะกว่ามาก ~14,400/วัน)
GROQ_MODEL=llama-3.3-70b-versatile

# ===== Notification (ใส่อันใดอันหนึ่งหรือทั้งคู่ก็ได้) =====
# Discord: Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=

# LINE Messaging API (LINE Notify ปิดบริการแล้ว มี.ค. 2025)
# สร้าง channel ที่ developers.line.biz แล้วเอา token + userId มาใส่
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# ===== Storage backend =====
# ทิ้งว่างไว้ = เก็บลงไฟล์ JSON ในโฟลเดอร์ data/ (เหมาะกับรันในเครื่อง)
# บน Vercel ให้ใส่ค่าจาก Upstash Redis (Vercel > Storage > Upstash) แทน
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== Google Sheets (optional mirror) =====
GOOGLE_SHEETS_CREDENTIALS_FILE=
GOOGLE_SHEET_NAME=StudentAssistant

# ===== Cron / misc =====
# ตั้งรหัสลับอะไรก็ได้ ใช้กันคนอื่นยิง /api/cron/remind (ต้องตั้งตรงกับ GitHub secret)
CRON_SECRET=
# รหัสลับสำหรับเซ็น session ของระบบล็อกอิน (ตั้งค่าคงที่ ไม่งั้นทุกคนหลุดล็อกอินเมื่อ redeploy)
SESSION_SECRET=

# ===== Web Push (แจ้งเตือนเด้งบนมือถือ/เครื่อง) =====
# สร้าง keypair ด้วย: python -c "from cryptography.hazmat.primitives.asymmetric import ec; ..." (ดู README)
# VAPID_PRIVATE_KEY เป็นความลับ (ต้องตั้ง), VAPID_PUBLIC_KEY มี default ในโค้ดแล้ว (จะ override ก็ได้)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com
# โซนเวลา (ค่าเริ่มต้นไทย) — สำคัญบน Vercel ที่นาฬิกาเป็น UTC
TZ=Asia/Bangkok
# โฟลเดอร์เก็บ JSON ตอนรันในเครื่อง
DATA_DIR=data
