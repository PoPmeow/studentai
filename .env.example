# ===== Core brain =====
# สร้าง key ฟรีได้ที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
MODEL=gemini-2.5-flash

# ===== Notification (ใส่อันใดอันหนึ่งหรือทั้งคู่ก็ได้) =====
# Discord: Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=

# LINE Messaging API (LINE Notify ปิดบริการแล้ว มี.ค. 2025)
# สร้าง channel ที่ developers.line.biz แล้วเอา token + userId มาใส่
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# ===== Storage backend =====
# ทิ้งว่างไว้ = เก็บลงไฟล์ JSON ในโฟลเดอร์ data/ (เหมาะกับรันในเครื่อง)
# บน Vercel ให้ใส่ค่าจาก Upstash Redis (Vercel > Storage > Upstash) แทน
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===== Google Sheets (optional mirror) =====
GOOGLE_SHEETS_CREDENTIALS_FILE=
GOOGLE_SHEET_NAME=StudentAssistant

# ===== Cron / misc =====
# ตั้งรหัสลับอะไรก็ได้ ใช้กันคนอื่นยิง /api/cron/remind (ต้องตั้งตรงกับ GitHub secret)
CRON_SECRET=
# โซนเวลา (ค่าเริ่มต้นไทย) — สำคัญบน Vercel ที่นาฬิกาเป็น UTC
TZ=Asia/Bangkok
# โฟลเดอร์เก็บ JSON ตอนรันในเครื่อง
DATA_DIR=data
